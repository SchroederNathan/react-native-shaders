{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "outDir": "plugin/build",
    "rootDir": "plugin/src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "verbatimModuleSyntax": false,
    "lib": ["ES2020"],
    "jsx": "react"
  },
  "include": ["plugin/src"],
  "exclude": ["src", "lib", "example", "node_modules"]
}
