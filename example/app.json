{
  "expo": {
    "name": "react-native-shaders-example",
    "slug": "react-native-shaders-example",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "rnshaders",
    "ios": {
      "bundleIdentifier": "com.schroedernathan.rnshaders.example",
      "supportsTablet": true
    },
    "android": {
      "package": "com.schroedernathan.rnshaders.example"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "./plugins/withReactNativeShaders",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to dither them."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to dither them.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save dithered images back to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
